# ============================================
# MCP Server Base — Environment Variables
# ============================================

# Server
MCP_SERVER_NAME=my-mcp-server
MCP_TRANSPORT=stdio           # stdio | sse | http
MCP_PORT=3001                 # Port for SSE/HTTP transports
MCP_LOG_LEVEL=info            # debug | info | warn | error

# Auth (for remote transports)
MCP_AUTH_TYPE=none             # none | api-key | oauth2
MCP_API_KEY=

# Your service credentials (add as needed)
# DATABASE_URL=postgresql://...
# GITHUB_TOKEN=ghp_...
# SLACK_TOKEN=xoxb-...
